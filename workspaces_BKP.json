{
  "_config": {
    "console_style": "Normal",
    "notifications": true
  },
  "Audio_Production": {
    "tags": [
      "Main"
    ],
    "services": [
      "Audiosrv"
    ],
    "executables": [
      "'C:/Program Files/Steinberg/Cubase 12/Cubase12.exe' --profile Live"
    ],
    "protected_processes": [
      "Cubase12",
      "WINWORD"
    ],
    "reverse_relations": [
      "wuauserv"
    ]
  },
  "Office": {
    "tags": [
      "Main"
    ],
    "services": [
      "ClickToRunSvc"
    ],
    "executables": [
      "'C:/Program Files/Microsoft OneDrive/OneDrive.exe'"
    ],
    "protected_processes": [
      "WINWORD",
      "EXCEL",
      "POWERPNT",
      "ONENOTE",
      "OUTLOOK",
      "MSACCESS",
      "MSPUB",
      "OneDrive",
      "lync",
      "msteams"
    ]
  },
  "SMB": {
    "tags": [
      "Services"
    ],
    "services": [
      "LanmanServer",
      "LanmanWorkstation"
    ],
    "firewall_groups": [
      "File and Printer Sharing"
    ]
  },
  "StarDesk": {
    "tags": [
      "Main"
    ],
    "services": [
      "StarDeskService"
    ],
    "executables": [
      "'C:/Program Files/StarDesk/StarDesk.exe'"
    ]
  }
}
